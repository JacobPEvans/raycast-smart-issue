{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "smart-issue",
  "title": "Smart Issue Creator",
  "description": "AI-powered GitHub issue creation using local LLM inference",
  "icon": "icon.png",
  "author": "JacobPEvans",
  "license": "MIT",
  "categories": ["Developer Tools", "Productivity"],
  "commands": [
    {
      "name": "create-issue",
      "title": "Create Smart Issue",
      "description": "Generate and create a GitHub issue from a brief idea",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "githubToken",
      "title": "GitHub Token",
      "description": "Personal access token with 'repo' scope",
      "type": "password",
      "required": true
    },
    {
      "name": "githubOrg",
      "title": "GitHub Organization/User",
      "description": "Your GitHub username or org for fetching repos",
      "type": "textfield",
      "required": true
    },
    {
      "name": "llmUrl",
      "title": "LLM Server URL",
      "description": "Local LLM inference endpoint (OpenAI-compatible)",
      "type": "textfield",
      "default": "http://localhost:11434",
      "required": false
    },
    {
      "name": "model",
      "title": "AI Model",
      "description": "Model for issue generation",
      "type": "textfield",
      "default": "mlx-community/Qwen3.5-27B-4bit",
      "required": false
    },
    {
      "name": "fallbackModel",
      "title": "Fallback Model",
      "description": "Used when primary model is unavailable (empty = auto-detect)",
      "type": "textfield",
      "default": "",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.87.0",
    "@raycast/utils": "^2.0.0",
    "@octokit/rest": "^22.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.0",
    "typescript": "^6.0.0",
    "@types/node": "25.x"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix"
  }
}
